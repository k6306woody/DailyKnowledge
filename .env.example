# 複製此檔為 .env，填入真實的 API Key
# ⚠️ 不要 commit .env 到 git！

ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Instagram Graph API ──────────────────────────────────────────────────
# 取得方式：
#   1. Facebook for Developers → 建立 App → Instagram Graph API
#   2. 申請 instagram_basic + instagram_content_publish 權限
#   3. 換取 Long-lived Token（60天）後填入以下欄位
#   詳細步驟：https://developers.facebook.com/docs/instagram-api/getting-started

IG_ACCESS_TOKEN=        # 60-day long-lived token (EAAxxxxxxxx)
IG_BUSINESS_ID=         # Instagram Business Account 數字 ID
IG_APP_ID=              # Facebook App ID（token 刷新用）
IG_APP_SECRET=          # Facebook App Secret（token 刷新用）
